# ============================================================
# Backend Environment Variables Configuration Guide
# ============================================================
# PURPOSE: This file configures your Flask backend for production deployment
#
# SETUP INSTRUCTIONS:
# 1) Copy this file: cp .env.example .env
# 2) Replace ALL placeholder values with your actual credentials
# 3) Never commit .env to git (already in .gitignore)
# 4) Set these same variables in Heroku dashboard (Settings > Config Vars)
#
# IMPORTANT NOTES:
# - Changes to .env require server restart to take effect
# - In Heroku, changes via dashboard restart dyno automatically
# - Keep quotes OFF unless value contains spaces
# - Use DEBUG_MODE=1 only in development (increases log costs in production)
# ============================================================

# =========================
# API KEYS (REQUIRED FOR PRODUCTION)
# =========================
# PINECONE_API_KEY: Your Pinecone vector database API key
# - Get from: https://app.pinecone.io/ > API Keys
# - Used for both RAG (NCERT content) and PYQ (practice questions) retrieval
# - Without this, backend will fail to start
PINECONE_API_KEY=your_pinecone_api_key_here

# OPENAI_API_KEY: Primary LLM provider for answer generation
# - Get from: https://platform.openai.com/api-keys
# - Used for gpt-4o-mini model (default, cost-effective)
# - Backend falls back to Groq if OpenAI fails/times out
OPENAI_API_KEY=your_openai_api_key_here

# OPENAI_MODEL_NAME: Which OpenAI model to use
# - Recommended: gpt-4o-mini (fastest, cheapest, good quality)
# - Alternatives: gpt-4o, gpt-3.5-turbo
# - Changing this affects response quality and API costs
OPENAI_MODEL_NAME=gpt-4o-mini

# OPENAI_TIMEOUT_SECONDS: How long to wait for OpenAI response before timing out
# - Default 20 seconds is recommended for gpt-4o-mini
# - If you see frequent timeouts, increase to 30-40
# - Too high = slow responses, too low = frequent fallback to Groq
OPENAI_TIMEOUT_SECONDS=20

# GROQ_API_KEY: Fallback LLM provider (free tier available)
# - Get from: https://console.groq.com/keys
# - Used when OpenAI fails, times out, or rate-limits
# - Uses llama-3.1-8b-instant (fast, free, good quality)
GROQ_API_KEY=your_groq_api_key_here

# GROQ_MODEL_NAME: Which Groq model to use as fallback
# - Recommended: llama-3.1-8b-instant (fastest)
# - Alternatives: llama-3.3-70b-versatile, mixtral-8x7b-32768
GROQ_MODEL_NAME=llama-3.1-8b-instant

# HF_API_KEY: Hugging Face API key (OPTIONAL)
# - Only needed if USE_HF_EMBEDDINGS=1 (not recommended for production)
# - Leave as placeholder if using local embeddings (default)
HF_API_KEY=your_hf_api_key_here

# =========================
# FLASK APP RUNTIME
# =========================
# FLASK_ENV: Sets Flask environment mode
# - 'development': Enables debug mode, auto-reload, detailed error pages
# - 'production': Disables debug, uses optimized settings
# For Heroku deployment, MUST set to 'production'
FLASK_ENV=development
FLASK_DEBUG=1

# PORT: Which port Flask listens on
# Heroku sets this automatically via $PORT, no need to change
PORT=5000

# DEBUG_MODE: Controls verbose logging (independent of FLASK_ENV)
# - Set to 1: Enables detailed debug prints (use in development only)
# - Set to 0: Disables debug prints (REQUIRED for production - reduces Heroku log costs)
# IMPORTANT: Changing this requires server restart
# On Heroku: Update via dashboard > Settings > Config Vars, dyno restarts automatically
DEBUG_MODE=0

# =========================
# CORS SECURITY
# =========================
# ALLOWED_ORIGINS: Comma-separated list of frontend URLs allowed to access your API
# Example for production Vercel deployment:
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-app-git-main.vercel.app
#
# IMPORTANT SECURITY NOTES:
# - In production (FLASK_ENV=production), backend enforces HTTPS-only origins
# - Never use wildcards (*) or http:// in production
# - Include all Vercel preview URLs if you want them to access backend
# - Changing this requires server restart
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# =========================
# PINECONE INDEX CONFIGURATION
# =========================
# RAG_INDEX_NAME: Pinecone index name for NCERT educational content
# - Default: ncert-local-bge-base
# - Must match the index name you created in Pinecone dashboard
# - Changing this requires server restart
RAG_INDEX_NAME=ncert-local-bge-base

# RAG_INDEX_DIMENSION: Vector dimension for RAG index
# - Default: 768 (for BAAI/bge-base-en-v1.5 embeddings)
# - MUST match your Pinecone index dimension
# - Do not change unless you recreate index with different embeddings
RAG_INDEX_DIMENSION=768

# MCQ_INDEX_NAME: Pinecone index name for practice questions (PYQ/MCQ)
# - Default: pyq-bge-768
# - Must match the MCQ index name in your Pinecone dashboard
# - Changing this requires server restart
MCQ_INDEX_NAME=pyq-bge-768

# =========================
# EMBEDDING CONFIGURATION
# =========================
# EMBEDDING_PROVIDER: Where to get embeddings for RAG content
# - 'local': Use sentence-transformers on your server (RECOMMENDED for production)
# - 'hf': Use Hugging Face API (requires HF_API_KEY, not recommended)
# - Local is faster and free, but requires ~450MB RAM for model
EMBEDDING_PROVIDER=local

# LOCAL_EMBEDDING_MODEL: Which sentence-transformer model to use locally
# - Default: BAAI/bge-base-en-v1.5 (768-dim, high quality, 438MB)
# - IMPORTANT: Must match RAG_INDEX_DIMENSION (768)
# - Model downloads on first server start (~5-10 seconds), then cached
# - Changing this requires recreating Pinecone index
LOCAL_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# EMBEDDING_DEVICE: Which device to run embeddings on
# - 'cpu': Use CPU (REQUIRED for Heroku - no GPU available)
# - 'gpu': Use GPU if available (not supported on Heroku Basic)
# - For Heroku Basic 512MB: MUST use 'cpu'
EMBEDDING_DEVICE=cpu

# MCQ_EMBEDDING_PROVIDER: Where to get embeddings for MCQ/PYQ retrieval
# - Same options as EMBEDDING_PROVIDER
# - Recommended: 'local' for consistency
MCQ_EMBEDDING_PROVIDER=local

# MCQ_EMBEDDING_MODEL: Model for MCQ embeddings
# - Default: BAAI/bge-base-en-v1.5 (same as RAG for consistency)
# - IMPORTANT: Must produce 768-dim vectors to match MCQ_INDEX_NAME dimension
# - Changing this requires recreating MCQ Pinecone index
MCQ_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# MCQ_EMBEDDING_DEVICE: Device for MCQ embeddings
# - Same options as EMBEDDING_DEVICE
# - For Heroku Basic: MUST use 'cpu'
MCQ_EMBEDDING_DEVICE=cpu

# =========================
# OPTIONAL: EMBEDDING FALLBACKS
# =========================
# These are alternative embedding providers - NOT RECOMMENDED for production
# Only enable if you have specific reasons (testing, experimentation)

# FastEmbed toggles (experimental, not well-tested)
USE_FASTEMBED=0
FASTEMBED_MODEL=BAAI/bge-base-en-v1.5
USE_FASTEMBED_FOR_MCQ=0
FASTEMBED_MCQ_MODEL=BAAI/bge-small-en-v1.5

# HuggingFace inference API toggles (requires HF_API_KEY, slower than local)
# Set USE_HF_EMBEDDINGS=1 only if you want remote embeddings via HF API
# NOT RECOMMENDED: Adds latency and requires API key
USE_HF_EMBEDDINGS=0
HF_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
HF_MCQ_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
HF_PROVIDER=auto

# =========================
# SEARCH & GENERATION DEFAULTS
# =========================
# These control the quality and speed of RAG answers and MCQ retrieval
# All can be overridden by frontend controls - these are just defaults

# DEFAULT_N_RESULTS: How many NCERT content chunks to retrieve for each query
# - Default: 5 chunks
# - Higher = more context but slower responses and higher LLM costs
# - Lower = faster but might miss relevant content
# - Recommended range: 3-10
DEFAULT_N_RESULTS=5

# DEFAULT_MCQ_THRESHOLD: Minimum similarity score for MCQ retrieval (0.0 to 1.0)
# - Default: 0.25 (retrieve questions with >25% similarity)
# - Higher = more strict filtering (fewer, more relevant questions)
# - Lower = more lenient (more questions, might include irrelevant ones)
# - Recommended range: 0.2-0.4
DEFAULT_MCQ_THRESHOLD=0.25

# DEFAULT_MCQ_LIMIT: Maximum number of MCQs to return
# - Default: 0 (no limit)
# - Set to 10-20 if you want to limit response size
DEFAULT_MCQ_LIMIT=0

# DEFAULT_ANSWER_TEMPERATURE: LLM creativity/randomness (0.0 to 1.0)
# - Default: 0.3 (fairly deterministic, educational content)
# - Higher = more creative but less consistent answers
# - Lower = more consistent but potentially repetitive
# - Recommended for education: 0.2-0.4
DEFAULT_ANSWER_TEMPERATURE=0.3

# DEFAULT_ANSWER_TOP_P: LLM nucleus sampling parameter (0.0 to 1.0)
# - Default: 0.9 (standard setting)
# - Controls diversity of word choices
# - Recommended: Keep at 0.9 unless you know what you're doing
DEFAULT_ANSWER_TOP_P=0.9

# DEFAULT_ANSWER_MAX_TOKENS: Maximum tokens in LLM response
# - Default: 1200 tokens (~900 words)
# - Higher = longer answers but higher API costs
# - Lower = shorter, more concise answers
# - Frontend answer-length controls override this
DEFAULT_ANSWER_MAX_TOKENS=1200

# EMBEDDING_CACHE_TTL: How long to cache embeddings (in seconds)
# - Default: 600 seconds (10 minutes)
# - Higher = less API calls but more RAM usage
# - Lower = more API calls but less RAM usage
# - For Heroku Basic: 600 is good balance
EMBEDDING_CACHE_TTL=600

# Cache management settings
# MAX_CACHE_SIZE: Maximum number of cached items before LRU eviction kicks in
# - Higher = better cache hit rate but more memory usage
# - For Heroku Basic (512MB): Keep at 100 or lower
# - Changing this requires server restart
MAX_CACHE_SIZE=100

# CACHE_CLEANUP_INTERVAL: How often (in seconds) to clean expired cache entries
# - Default 300 = cleanup every 5 minutes
# - Lower = more frequent cleanup but more CPU usage
# - Changing this requires server restart
CACHE_CLEANUP_INTERVAL=300

# =========================
# RATE LIMITING
# =========================
# RATE_LIMIT_MAX_REQUESTS: Maximum API requests allowed per user/IP in time window
# - Default 20 = allows 20 requests per minute
# - Increase if users hit limits frequently (check Heroku logs)
# - Decrease if you want stricter rate limiting
# - Changing this requires server restart
RATE_LIMIT_MAX_REQUESTS=20

# RATE_LIMIT_WINDOW_SECONDS: Time window for rate limiting (in seconds)
# - Default 60 = 1 minute window
# - Example: RATE_LIMIT_MAX_REQUESTS=20 + RATE_LIMIT_WINDOW_SECONDS=60 means:
#   Users can make 20 requests per minute, then must wait
# - Changing this requires server restart
RATE_LIMIT_WINDOW_SECONDS=60

# =========================
# SECURITY & MISCELLANEOUS
# =========================
# SECRET_KEY: Flask session encryption key
# - Generate a random string for production: python -c "import secrets; print(secrets.token_hex(32))"
# - Used for secure session management
# - Keep this secret, never share or commit to git
SECRET_KEY=your-secret-key-for-sessions

# ============================================================
# HEROKU DEPLOYMENT QUICK GUIDE
# ============================================================
# After setting up your Heroku app:
#
# 1. Set Config Vars (Settings > Config Vars in Heroku dashboard):
#    heroku config:set FLASK_ENV=production
#    heroku config:set DEBUG_MODE=0
#    heroku config:set PINECONE_API_KEY=your_actual_key
#    heroku config:set OPENAI_API_KEY=your_actual_key
#    heroku config:set GROQ_API_KEY=your_actual_key
#    heroku config:set ALLOWED_ORIGINS=https://your-frontend.vercel.app
#    heroku config:set MCQ_INDEX_NAME=pyq-bge-768
#    heroku config:set RATE_LIMIT_MAX_REQUESTS=20
#    heroku config:set RATE_LIMIT_WINDOW_SECONDS=60
#
# 2. Deploy:
#    git push heroku main
#
# 3. Check logs:
#    heroku logs --tail
#
# 4. Verify health:
#    curl https://your-app.herokuapp.com/api/health
#
# IMPORTANT NOTES:
# - All config changes in Heroku dashboard automatically restart dyno
# - Changes to local .env do NOT affect Heroku (must set via heroku config:set)
# - Heroku Basic dyno sleeps after 30min inactivity (first request takes ~10s)
# - Model downloads on first request (~5-10s), then cached in dyno memory
# - Dyno restarts daily, causing model re-download (normal behavior)
#
# MEMORY OPTIMIZATION FOR HEROKU BASIC (512MB):
# - Using 1 worker + 4 threads (configured in Procfile)
# - BGE-base model: ~450MB RAM
# - Remaining ~60MB for Flask + requests + cache
# - If you see R14 errors (memory quota exceeded), reduce MAX_CACHE_SIZE
#
# COST OPTIMIZATION:
# - Keep DEBUG_MODE=0 to reduce log volume (Heroku charges for high log retention)
# - Use OPENAI_MODEL_NAME=gpt-4o-mini for lowest API costs
# - Set RATE_LIMIT_MAX_REQUESTS to prevent abuse/excessive API usage
# ============================================================