# ============================================================
# Frontend Environment Variables (.env.example)
# ============================================================
# SETUP INSTRUCTIONS:
# 1) Copy this file: cp .env.example .env
# 2) Replace ALL placeholder values with your actual credentials
# 3) Never commit .env to git (already in .gitignore)
# 4) For Vercel deployment: Set these in Vercel dashboard (Settings > Environment Variables)
#
# IMPORTANT NOTES:
# - All Firebase values are REQUIRED for production
# - VITE_API_BASE_URL must point to your deployed backend (Heroku)
# - Build will fail if required variables are missing (enforced in vite.config.js)
# - Environment variables are embedded in build at compile-time (not runtime)
# ============================================================

# =========================
# BACKEND API URL (REQUIRED)
# =========================
# VITE_API_BASE_URL: URL of your Flask backend
# Development: Use proxy (vite handles this automatically, no need to set)
# Production: MUST be your Heroku backend URL
# 
# Example for Heroku:
# VITE_API_BASE_URL=https://your-app-name.herokuapp.com
#
# IMPORTANT: 
# - Do NOT include /api suffix (handled automatically by api.js)
# - Must use HTTPS in production (enforced by backend CORS)
# - Build will fail if this is not set in production
VITE_API_BASE_URL=http://localhost:5000

# =========================
# EXTERNAL APP LINKS (OPTIONAL)
# =========================
# Sidebar quick links
# - If set, buttons open these URLs in a new tab
# - If unset, sidebar shows a fallback "coming soon" modal
VITE_PRATIYOGITA_YOGYA_URL=
VITE_PRATIYOGITA_MARG_URL=

# =========================
# FIREBASE CONFIGURATION (REQUIRED)
# =========================
# Get these values from Firebase Console:
# https://console.firebase.google.com/ > Project Settings > General
#
# VITE_FIREBASE_API_KEY: Your Firebase Web API key
# - Found in Firebase Console > Project Settings
# - Safe to expose in frontend (protected by Firebase security rules)
VITE_FIREBASE_API_KEY=your_api_key_here

# VITE_FIREBASE_AUTH_DOMAIN: Firebase Auth domain
# - Format: your-project-id.firebaseapp.com
# - Used for OAuth redirects
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com

# VITE_FIREBASE_PROJECT_ID: Your Firebase project ID
# - Found in Firebase Console > Project Settings
# - Must match your Firestore project
VITE_FIREBASE_PROJECT_ID=your-project-id

# VITE_FIREBASE_STORAGE_BUCKET: Firebase Storage bucket
# - Format: your-project-id.appspot.com
# - Required even if not using Storage
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# VITE_FIREBASE_MESSAGING_SENDER_ID: FCM sender ID
# - Found in Firebase Console > Project Settings > Cloud Messaging
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id

# VITE_FIREBASE_APP_ID: Firebase app ID
# - Found in Firebase Console > Project Settings
# - Required for Firebase initialization
VITE_FIREBASE_APP_ID=your_app_id

# VITE_FIREBASE_MEASUREMENT_ID: Google Analytics measurement ID (OPTIONAL)
# - Only needed if using Firebase Analytics
# - Can be left empty or omitted
# VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# =========================
# DEVELOPMENT SETTINGS (OPTIONAL)
# =========================
# VITE_USE_FIREBASE_EMULATOR: Use local Firebase emulators
# - Set to 'true' only when running Firebase emulators locally
# - Keep unset or 'false' for production
# VITE_USE_FIREBASE_EMULATOR=false

# VITE_LOG_LEVEL: Logging verbosity level
# - Options: 'debug', 'info', 'warn', 'error'
# - Default: 'info'
# - In production, logger auto-disables verbose console logging
# VITE_LOG_LEVEL=info

# ============================================================
# VERCEL DEPLOYMENT GUIDE
# ============================================================
# After creating your Vercel project:
#
# 1. Set Environment Variables in Vercel Dashboard:
#    - Go to: Settings > Environment Variables
#    - Add all VITE_* variables above with actual values
#    - Set for: Production, Preview, Development (check all three)
#
# 2. Critical Variables (MUST set):
#    VITE_API_BASE_URL=https://your-app-name.herokuapp.com
#    VITE_FIREBASE_API_KEY=your_actual_key
#    VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
#    VITE_FIREBASE_PROJECT_ID=your-project-id
#    VITE_FIREBASE_APP_ID=your_actual_app_id
#    VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
#    VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
#
# 3. Deploy:
#    vercel --prod
#
# 4. Verify:
#    - Check browser console for Firebase initialization success
#    - Test backend connectivity (should see API calls to Heroku)
#    - Verify auth flow works
#
# IMPORTANT NOTES:
# - Vercel auto-detects Vite projects and builds correctly
# - Environment variables are compiled into build at deploy time
# - Changing env vars requires redeployment (trigger via dashboard)
# - Preview deployments get same env vars as production
# - Never use http:// URLs in production (CORS will block)
# ============================================================

