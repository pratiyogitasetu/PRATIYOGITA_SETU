# Optional: use local Firebase emulators in dev
VITE_USE_FIREBASE_EMULATOR=false

# Optional external links for navbar
VITE_PRATIYOGITA_MARG_URL=/
VITE_PRATIYOGITA_YOGYA_URL=https://parikshayogya.vercel.app
VITE_PRATIYOGITA_GYAN_URL=https://www.pratiyogitagyan.com

