# Firebase Configuration (must be EXACTLY the same project as FRONTEND/.env)
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
VITE_FIREBASE_APPCHECK_SITE_KEY=your_recaptcha_v3_site_key

# Firestore exam-data collections
VITE_EXAM_CATALOG_COLLECTION=examCatalog
VITE_EXAM_CATALOG_DOC_ID=allExamNames
VITE_EXAM_DATA_COLLECTION=examData

# Cross-app navigation links
VITE_PRATIYOGITA_GYAN_URL=https://gyan.psetu.com/
VITE_PRATIYOGITA_MARG_URL=https://marg.psetu.com/
